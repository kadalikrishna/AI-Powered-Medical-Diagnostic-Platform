PORT=4000
# Local dev without Docker/Postgres: set USE_PGLITE=1 (embedded DB). Otherwise use DATABASE_URL.
USE_PGLITE=1
DATABASE_URL=postgresql://diagnostic:diagnostic@localhost:5432/diagnostic
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
AI_SERVICE_URL=http://127.0.0.1:8000
